rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'mondal.saikat185@gmail.com';
    }

    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || (resource != null && resource.data.email == request.auth.token.email) || isAdmin());
      
      allow create: if request.auth != null && (request.auth.uid == uid || isAdmin());
      
      allow update: if isAdmin() || (
        request.auth != null && request.auth.uid == uid &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.phone == resource.data.phone &&
        (
          (request.resource.data.activeDeviceId == resource.data.activeDeviceId)
          ||
          (
            resource.data.status == 'active' &&
            (resource.data.activeDeviceId == null || resource.data.activeDeviceId == '') &&
            request.resource.data.activeDeviceId is string &&
            request.resource.data.activeDeviceId.size() > 0
          )
        )
      );

      allow delete: if isAdmin() || (request.auth != null && resource.data.email == request.auth.token.email);
    }

    match /usage_logs/{logId} {
      allow create: if request.auth != null;
      allow read, write: if isAdmin();
    }
  }
}
